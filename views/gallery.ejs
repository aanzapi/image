<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .image-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 1.5rem;
        }
        .image-card {
            transition: all 0.3s ease;
        }
        .image-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }
    </style>
</head>
<body class="bg-gray-50">
    <!-- Navigation -->
    <nav class="bg-white shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex items-center">
                    <a href="/" class="text-2xl font-bold text-blue-600">ImgHost</a>
                </div>
                <div class="flex items-center space-x-4">
                    <a href="/" class="text-gray-700 hover:text-blue-600 transition">Home</a>
                    <a href="/admin" class="text-gray-700 hover:text-blue-600 transition">Admin</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Gallery Header -->
    <div class="bg-white shadow-sm">
        <div class="max-w-7xl mx-auto px-4 py-8">
            <h1 class="text-3xl font-bold text-gray-800">Image Gallery</h1>
            <p class="text-gray-600 mt-2">Temukan dan jelajahi semua gambar</p>
            
            <!-- Search -->
            <div class="mt-4">
                <form method="GET" class="flex gap-2">
                    <input type="text" name="search" value="<%= search %>" 
                           placeholder="Cari gambar..." 
                           class="flex-1 p-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <button type="submit" class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition">
                        Cari
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Gallery Grid -->
    <div class="max-w-7xl mx-auto px-4 py-12">
        <% if (images.length > 0) { %>
            <div class="image-grid">
                <% images.forEach(image => { %>
                    <a href="/gallery/<%= image.filename %>" class="image-card bg-white rounded-lg overflow-hidden shadow-md">
                        <img src="/<%= image.filename %>" alt="<%= image.original_name %>" 
                             class="w-full h-56 object-cover">
                        <div class="p-4">
                            <p class="text-sm font-medium text-gray-800 truncate"><%= image.original_name %></p>
                            <p class="text-xs text-gray-500 mt-1"><%= new Date(image.uploaded_at).toLocaleDateString() %></p>
                            <p class="text-xs text-gray-400"><%= (image.size / 1024).toFixed(2) %> KB</p>
                        </div>
                    </a>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center py-12">
                <svg class="mx-auto h-16 w-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                <p class="text-xl text-gray-600 mt-4">Belum ada gambar</p>
                <p class="text-gray-400">Mulai upload gambar sekarang!</p>
                <a href="/" class="inline-block mt-4 bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition">
                    Upload Gambar
                </a>
            </div>
        <% } %>
    </div>
</body>
</html>