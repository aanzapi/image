<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Image Hosting</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .drop-zone {
            border: 2px dashed #3b82f6;
            border-radius: 1rem;
            padding: 3rem;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        .drop-zone.dragover {
            background-color: #eff6ff;
            border-color: #2563eb;
            transform: scale(1.02);
        }
        .upload-result {
            animation: slideUp 0.5s ease;
        }
        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .copy-btn {
            transition: all 0.3s ease;
        }
        .copy-btn:hover {
            transform: scale(1.05);
        }
        .image-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 1rem;
        }
    </style>
</head>
<body class="bg-gray-50">
    <!-- Navigation -->
    <nav class="bg-white shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex items-center">
                    <a href="/" class="text-2xl font-bold text-blue-600">ImgHost</a>
                </div>
                <div class="flex items-center space-x-4">
                    <a href="/gallery" class="text-gray-700 hover:text-blue-600 transition">Gallery</a>
                    <a href="/admin" class="text-gray-700 hover:text-blue-600 transition">Admin</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <div class="bg-gradient-to-r from-blue-600 to-blue-800 text-white">
        <div class="max-w-4xl mx-auto px-4 py-20 text-center">
            <h1 class="text-4xl md:text-6xl font-bold mb-4">Image Hosting</h1>
            <p class="text-xl md:text-2xl mb-8">Upload dan bagikan gambar Anda dengan mudah</p>
            
            <!-- Upload Area -->
            <div class="bg-white rounded-xl shadow-xl p-8 text-gray-800">
                <div id="uploadZone" class="drop-zone">
                    <div class="text-center">
                        <svg class="mx-auto h-12 w-12 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                        <p class="mt-4 text-lg font-medium">Drag & drop gambar di sini</p>
                        <p class="text-sm text-gray-500">atau klik untuk memilih file</p>
                        <p class="text-xs text-gray-400 mt-2">Support: JPG, JPEG, PNG, WEBP (Max 10MB)</p>
                        <input type="file" id="fileInput" accept="image/jpeg,image/jpg,image/png,image/webp" class="hidden">
                    </div>
                </div>

                <!-- Upload Progress -->
                <div id="uploadProgress" class="hidden mt-4">
                    <div class="w-full bg-gray-200 rounded-full h-2.5">
                        <div class="bg-blue-600 h-2.5 rounded-full transition-all duration-300" style="width: 0%"></div>
                    </div>
                    <p class="text-sm text-gray-600 text-center mt-2" id="progressText">Uploading...</p>
                </div>

                <!-- Upload Result -->
                <div id="uploadResult" class="hidden mt-6 upload-result">
                    <div class="bg-gray-50 rounded-lg p-4">
                        <img id="previewImage" src="" alt="Preview" class="max-h-64 mx-auto rounded-lg shadow-md">
                        <div class="mt-4">
                            <div class="flex items-center justify-center space-x-2">
                                <input type="text" id="imageUrl" readonly class="flex-1 p-2 border rounded-lg bg-white text-sm">
                                <button onclick="copyLink()" class="copy-btn bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition">
                                    Copy
                                </button>
                                <button onclick="openImage()" class="copy-btn bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition">
                                    Open
                                </button>
                            </div>
                            <button onclick="resetUpload()" class="mt-4 w-full bg-gray-200 text-gray-800 px-4 py-2 rounded-lg hover:bg-gray-300 transition">
                                Upload Lagi
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Images -->
    <div class="max-w-7xl mx-auto px-4 py-12">
        <h2 class="text-2xl font-bold text-gray-800 mb-6">Recent Uploads</h2>
        <% if (images.length > 0) { %>
            <div class="image-grid">
                <% images.forEach(image => { %>
                    <a href="/gallery/<%= image.filename %>" class="block bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
                        <img src="/<%= image.filename %>" alt="<%= image.original_name %>" class="w-full h-48 object-cover">
                        <div class="p-3">
                            <p class="text-sm text-gray-600 truncate"><%= image.original_name %></p>
                            <p class="text-xs text-gray-400"><%= new Date(image.uploaded_at).toLocaleDateString() %></p>
                        </div>
                    </a>
                <% }) %>
            </div>
        <% } else { %>
            <p class="text-gray-500 text-center py-8">Belum ada gambar yang diupload</p>
        <% } %>
    </div>

    <script>
        const uploadZone = document.getElementById('uploadZone');
        const fileInput = document.getElementById('fileInput');
        const uploadProgress = document.getElementById('uploadProgress');
        const uploadResult = document.getElementById('uploadResult');
        const progressBar = document.querySelector('#uploadProgress .bg-blue-600');
        const progressText = document.getElementById('progressText');
        const previewImage = document.getElementById('previewImage');
        const imageUrl = document.getElementById('imageUrl');

        uploadZone.addEventListener('click', () => fileInput.click());

        uploadZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            uploadZone.classList.add('dragover');
        });

        uploadZone.addEventListener('dragleave', () => {
            uploadZone.classList.remove('dragover');
        });

        uploadZone.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadZone.classList.remove('dragover');
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                handleUpload(files[0]);
            }
        });

        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                handleUpload(e.target.files[0]);
            }
        });

        function handleUpload(file) {
            // Validate file type
            const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
            if (!allowedTypes.includes(file.type)) {
                alert('Format file tidak didukung. Gunakan JPG, JPEG, PNG, atau WEBP.');
                return;
            }

            // Validate file size (10MB)
            if (file.size > 10 * 1024 * 1024) {
                alert('Ukuran file maksimal 10MB.');
                return;
            }

            const formData = new FormData();
            formData.append('image', file);

            uploadZone.classList.add('hidden');
            uploadProgress.classList.remove('hidden');
            progressBar.style.width = '0%';
            progressText.textContent = 'Mengupload...';

            const xhr = new XMLHttpRequest();
            xhr.open('POST', '/api/upload');

            xhr.upload.onprogress = (e) => {
                if (e.lengthComputable) {
                    const percent = (e.loaded / e.total) * 100;
                    progressBar.style.width = percent + '%';
                    progressText.textContent = `Uploading ${Math.round(percent)}%`;
                }
            };

            xhr.onload = () => {
                uploadProgress.classList.add('hidden');
                if (xhr.status === 201) {
                    const response = JSON.parse(xhr.responseText);
                    if (response.success) {
                        previewImage.src = response.url;
                        imageUrl.value = response.url;
                        uploadResult.classList.remove('hidden');
                        progressText.textContent = 'Upload selesai!';
                    } else {
                        alert('Upload gagal: ' + (response.error || 'Unknown error'));
                        resetUpload();
                    }
                } else {
                    alert('Upload gagal. Silakan coba lagi.');
                    resetUpload();
                }
            };

            xhr.onerror = () => {
                uploadProgress.classList.add('hidden');
                alert('Upload gagal. Silakan coba lagi.');
                resetUpload();
            };

            xhr.send(formData);
        }

        function copyLink() {
            const url = imageUrl.value;
            navigator.clipboard.writeText(url).then(() => {
                const btn = document.querySelector('.copy-btn');
                const originalText = btn.textContent;
                btn.textContent = 'Copied!';
                btn.classList.add('bg-green-600');
                setTimeout(() => {
                    btn.textContent = originalText;
                    btn.classList.remove('bg-green-600');
                }, 2000);
            }).catch(() => {
                // Fallback
                imageUrl.select();
                document.execCommand('copy');
                alert('Link copied to clipboard!');
            });
        }

        function openImage() {
            window.open(imageUrl.value, '_blank');
        }

        function resetUpload() {
            uploadResult.classList.add('hidden');
            uploadZone.classList.remove('hidden');
            fileInput.value = '';
            progressBar.style.width = '0%';
            progressText.textContent = '';
        }
    </script>
</body>
</html>